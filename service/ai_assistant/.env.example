# =============================================
# AI 校园助手 – 环境变量
# 将此文件复制到 .env 并填写值。
# =============================================

# --- 应用程序 ---
APP_NAME="AI 校园助手"
APP_VERSION="1.0.0"
DEBUG=false

# --- MySQL 数据库 ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ai_user
MYSQL_PASSWORD=change_me_db_password
MYSQL_DATABASE=ai_assistant

# --- Redis 数据库 ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# --- JWT ---
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AES (密码传输加密) ---
# 必须与前端 CryptoJS 使用的密钥一致
# AES_SECRET_KEY: 16/24/32 字符的 UTF-8 字符串 (对应 AES-128/192/256)
AES_SECRET_KEY=cHanGzIhAo521703

# 用于 DID 生成的盐值（保持机密）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
DID_SALT=change_me_did_salt_at_least_32_chars_long

# --- 阿里云 DashScope (百炼) ---
ALI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 是否信任系统代理环境变量(HTTP_PROXY/HTTPS_PROXY)
# 本地开发建议 false，避免 Conda/IDE 代理注入导致 DashScope 连接失败
DASHSCOPE_TRUST_ENV_PROXY=false

# --- LLM 模型配置 ---
# 意图理解
LLM_MODEL_INTENT_CLASSIFY=qwen-turbo
# 查询改写模型
LLM_MODEL_QUERY_REWRITE=qwen-turbo
# 最终回答生成模型
LLM_MODEL_FINAL_ANSWER=qwen-plus
# 思考决策/工具规划
LLM_MODEL_TOOL_PLANNER=qwen-plus
# 向量检索 query 拆解模型
LLM_MODEL_VECTOR_DECOMPOSE=qwen-turbo
# hybrid 路径重排模型
LLM_MODEL_HYBRID_RERANK=qwen-turbo
# 安全检测模型
LLM_MODEL_SAFETY_CHECK=qwen-turbo
# 图像理解模型
LLM_MODEL_IMAGE_UNDERSTANDING=qwen-vl-plus
# 语音识别模型
LLM_MODEL_SPEECH_RECOGNITION=paraformer-realtime-v1

# 向量搜索的知识库 app-id（百炼 RAG）– 旧模式
BAILIAN_APP_ID=your_bailian_app_id

# --- 阿里云百炼检索 API ---
# 如果已配置，助手将使用检索 API 直接进行知识库检索，
# 而不是使用旧的 Application.call()。
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
BAILIAN_WORKSPACE_ID=
BAILIAN_INDEX_ID=
BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com

# --- 缓存 TTL ---
CACHE_TTL_SENSITIVE=1800   # 30 分钟  (敏感 / 隐私查询)
CACHE_TTL_NORMAL=86400     # 1 天       (一般查询)
